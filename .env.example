# AI backend — points at a local Ollama instance by default.
# Any OpenAI-compatible endpoint works (LM Studio, vLLM, etc).
OLLAMA_BASE_URL=http://localhost:11434/v1

# API key for the backend. Ollama doesn't need one, so this defaults to the
# dummy value "ollama" when unset. Set this when using a hosted endpoint that
# requires authentication (e.g. OpenAI, a remote vLLM instance, etc).
#API_KEY=your-api-key-here

# Vision-capable model to use. Must be pulled in Ollama first:
#   ollama pull llava
# Other options: moondream, minicpm-v, llava:13b, llava-llama3
MODEL=llava
